# =====================================================================
# Loxia — Environment variables template
# Copy this file to `.env` and fill in real values for local dev:
#     cp .env.example .env
# `.env` is gitignored and must NEVER be committed.
# =====================================================================

# ---------- PostgreSQL (single container, multiple databases) ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=loxia-db
POSTGRES_PORT=5432

# Per-service database names (created by scripts/init-multi-db.sh)
AUTH_DB_NAME=auth_db
CATALOG_DB_NAME=catalog_db
RENTAL_DB_NAME=rental_db
NOTIFICATION_DB_NAME=notification_db

# ---------- JWT ----------
# IMPORTANT: replace with a long random string (32+ chars) in real .env
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# ---------- Inter-service URLs (Docker network DNS) ----------
AUTH_SERVICE_URL=http://auth-service:8081
CATALOG_SERVICE_URL=http://catalog-service:8082
RENTAL_SERVICE_URL=http://rental-service:8083
NOTIFICATION_SERVICE_URL=http://notification-service:8084

# ---------- Spring profiles ----------
SPRING_PROFILES_ACTIVE=docker

# ---------- pgAdmin (dev only) ----------
# NOTE: pgAdmin rejects non-public TLDs like .local — use a real TLD.
PGADMIN_DEFAULT_EMAIL=admin@loxia.dev
PGADMIN_DEFAULT_PASSWORD=admin

# ---------- Frontend ----------
# Base URL the React app uses to call the gateway
VITE_API_BASE_URL=http://localhost:8080
